{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build",
        "outputDirectory": "dist/client"
      }
    },
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "dist/server/**"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/dist/server/server.js" }
  ]
}